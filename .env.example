# GCP
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1

# Neo4j (VM static IP from Terraform output neo4j_static_ip)
NEO4J_URI=bolt://STATIC_IP:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# AWS (for Dataproc to read S3)
AWS_S3_BUCKET=deluxe-v2-cdc-out
AWS_ACCESS_KEY_ID=your-hmac-access-key
AWS_SECRET_ACCESS_KEY=your-hmac-secret-key

# GCS buckets (from Terraform outputs)
GCS_WATERMARK_BUCKET=your-gcp-project-id-watermark
GCS_SEED_BUCKET=your-gcp-project-id-seed
ETL_ARTIFACTS_BUCKET=your-gcp-project-id-etl-artifacts

# Dispatcher / Pub/Sub
PUBSUB_SUBSCRIPTION=cdc-events-sub
DATAPROC_BATCH_TEMPLATE=
ETL_SUBNET=regions/us-central1/subnetworks/subnet-data

# GitHub Actions secrets (set in repo settings, not here)
# WIF_PROVIDER=projects/PROJECT_NUMBER/locations/global/workloadIdentityPools/github-actions-pool/providers/github-actions-provider
# WIF_SERVICE_ACCOUNT=github-actions-sa@PROJECT_ID.iam.gserviceaccount.com
